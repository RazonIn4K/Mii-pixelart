# Cloudflare Pages security + caching headers.
# Format: path on the first line, then indented header lines.
#
# Email Routing note: Cloudflare Email Routing adds MX + SPF + DKIM records
# to the zone automatically when enabled. No _headers changes are needed for
# inbound mail — this file only controls HTTP response headers.

/*
  X-Content-Type-Options: nosniff
  # CSP's `frame-ancestors 'none'` below is the modern enforcement, but legacy
  # browsers (pre-Chromium Edge, old IE) only honor X-Frame-Options. DENY
  # matches the CSP intent — nothing should iframe the studio.
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=(), browsing-topics=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-DNS-Prefetch-Control: on
  # Content-Security-Policy: balances strictness with the third-party
  # integrations we genuinely need.
  #
  # Known-accepted Google CSP Evaluator warnings:
  #   - 'unsafe-inline' / 'unsafe-eval' on script-src: required by AdSense's
  #     inline ad tags and by Vite's HMR bootstrap. Removing them would break
  #     the site.
  #   - googlesyndication.com / doubleclick.net: Google itself flags these as
  #     JSONP-bypass surfaces. Inherent cost of loading AdSense; the only way
  #     to fully resolve is to move AdSense into a sandboxed iframe, which is
  #     a separate refactor.
  #
  # Per-directive notes:
  #   - script: self + AdSense (loaded only after consent) + Stripe.js.
  #     *.google.com was dropped — AdSense doesn't need it.
  #   - style: self + Google Fonts CSS. 'unsafe-inline' required by Tailwind v4
  #     and React's runtime style injection.
  #   - font: Google Fonts woff2.
  #   - img: anywhere over https + data: + blob: (hero CDN, og-image,
  #     studio preview blobs).
  #   - connect: self for our APIs, HIBP for password breach check, OpenRouter
  #     for AI, Cloudflare NEL for error reports.
  #   - frame: Stripe Checkout + AdSense ad frames.
  #   - frame-ancestors 'none' matches the X-Frame-Options: DENY above —
  #     nothing should iframe the studio.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://pagead2.googlesyndication.com https://*.googlesyndication.com https://*.doubleclick.net https://js.stripe.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; media-src 'self' blob:; connect-src 'self' https://api.pwnedpasswords.com https://openrouter.ai https://*.openrouter.ai https://*.pages.dev https://a.nel.cloudflare.com https://pagead2.googlesyndication.com https://api.stripe.com https://r.stripe.com; frame-src https://checkout.stripe.com https://*.stripe.com https://googleads.g.doubleclick.net https://www.google.com; form-action 'self' https://checkout.stripe.com; frame-ancestors 'none'; base-uri 'self'; object-src 'none'; upgrade-insecure-requests
  # Trusted Types in REPORT-ONLY first so we observe what would break in
  # production without enforcing. React 18 + Vite don't auto-register a
  # Trusted Types policy, so flipping this to enforce mode prematurely would
  # break document.innerHTML calls. Move to enforce once we register a
  # default policy and confirm no production violations.
  Content-Security-Policy-Report-Only: require-trusted-types-for 'script'; trusted-types default 'allow-duplicates'

# Long cache for hashed Vite build artifacts.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Never cache the SPA entry; we need fresh asset references after deploys.
/index.html
  Cache-Control: no-cache

# Never cache API responses at the edge.
/api/*
  Cache-Control: no-store
